# OS
.DS_Store

# APK / build output from scripts/build_android.sh
/Builds/

# --- Unity project (unity/) ---
unity/[Ll]ibrary/
unity/[Tt]emp/
unity/[Oo]bj/
unity/[Bb]uild/
unity/[Bb]uilds/
unity/[Ll]ogs/
unity/[Uu]ser[Ss]ettings/
unity/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!unity/[Aa]ssets/**/*.meta

# Autogenerated VS/Rider files
*.csproj
*.unityproj
*.sln
*.suo
*.user
.vs/
.idea/

# --- Web app (web/) ---
web/node_modules/
web/dist/
web/.vite/
*.log

# Vercel link/build dirs (created by `vercel pull`/`vercel build`; never commit)
.vercel
web/.vercel

# --- Android wrapper (android/) ---
android/.gradle/
android/build/
android/app/build/
android/local.properties
# Generated at build time by the copyWebAssets Gradle task.
android/app/src/main/assets/web/
