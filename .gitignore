# OS
.DS_Store

# Build/deploy output (e.g. scripts/deploy_board_web.sh -> Builds/Board/*.webapp.zip)
/Builds/

# Autogenerated VS/Rider files
*.csproj
*.sln
*.suo
*.user
.vs/
.idea/

# --- Web app (web/) ---
web/node_modules/
web/dist/
web/.vite/
*.log

# Vercel link/build dirs (created by `vercel pull`/`vercel build`; never commit)
.vercel
web/.vercel

# --- Android wrapper (android/) ---
android/.gradle/
android/build/
android/app/build/
android/local.properties
# Generated at build time by the copyWebAssets Gradle task.
android/app/src/main/assets/web/
